---
import Tabelle from './Tabelle.astro';
import Spielplan from './Spielplan.astro';
import Hinweis from './Hinweis.astro';
import type { MannschaftWettbewerb } from '../lib/spieldaten';
import { spieleChronologisch, tabellenZeilenFuerUi, wettbewerbLabel } from '../lib/spieldaten';

interface Props {
  name: string;
  wettbewerbe: MannschaftWettbewerb[];
  demo: boolean;
  stand: string;
}

const { name, wettbewerbe, demo, stand } = Astro.props;

const tabelleSpalten = [
  { key: 'platz', label: 'Pl.' },
  { key: 'team', label: 'Mannschaft' },
  { key: 'spiele', label: 'Sp.' },
  { key: 'punkte', label: 'Pkt.' },
  { key: 'diff', label: 'Diff.' },
];
---

<section class="mannschafts-block abschnitt" aria-labelledby={`mannschaft-${name}`}>
  <h2 id={`mannschaft-${name}`} class="mannschafts-block__titel">
    Mannschaft {name}
  </h2>

  {demo && (
    <Hinweis variant="demo">
      Beispieldaten – Saison 26/27 startet im September
    </Hinweis>
  )}

  {wettbewerbe.map(({ tabellen, spielplan }) => (
    <div class="mannschafts-block__wettbewerb">
      <h3 class="mannschafts-block__untertitel">
        {wettbewerbLabel(tabellen.wettbewerb)}
        <span class="mannschafts-block__liga">{tabellen.ligaName}</span>
      </h3>

      <Tabelle
        caption={`Tabelle – ${tabellen.ligaName}`}
        spalten={tabelleSpalten}
        zeilen={tabellenZeilenFuerUi(tabellen.tabelle)}
        stand={stand}
      />

      <p class="mannschafts-block__link">
        <a href={tabellen.myttTabelleUrl} rel="noopener noreferrer">
          Tabelle auf mytischtennis.de ansehen →
        </a>
      </p>

      <div class="mannschafts-block__spiele">
        <h4 class="mannschafts-block__spielplan-titel">Spielplan</h4>
        <Spielplan spiele={spieleChronologisch(spielplan.spiele)} />
      </div>

      <p class="mannschafts-block__link">
        <a href={spielplan.myttSpielplanUrl} rel="noopener noreferrer">
          Spielplan auf mytischtennis.de ansehen →
        </a>
      </p>
    </div>
  ))}
</section>
