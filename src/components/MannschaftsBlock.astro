---
import Tabelle from './Tabelle.astro';
import Hinweis from './Hinweis.astro';
import type { MannschaftSpielplan, MannschaftTabellen } from '../lib/spieldaten';
import { formatSpielDatum, tabellenZeilenFuerUi } from '../lib/spieldaten';

interface Props {
  mannschaftTabellen: MannschaftTabellen;
  mannschaftSpielplan: MannschaftSpielplan;
  demo: boolean;
  stand: string;
}

const { mannschaftTabellen, mannschaftSpielplan, demo, stand } = Astro.props;

const tabelleSpalten = [
  { key: 'platz', label: 'Pl.' },
  { key: 'team', label: 'Mannschaft' },
  { key: 'spiele', label: 'Sp.' },
  { key: 'punkte', label: 'Pkt.' },
  { key: 'diff', label: 'Diff.' },
];

const heute = new Date();
heute.setHours(0, 0, 0, 0);

function parseDatum(datum: string | null) {
  if (!datum) return 0;
  const t = new Date(`${datum}T00:00:00`).getTime();
  return Number.isNaN(t) ? 0 : t;
}

const kommende = mannschaftSpielplan.spiele
  .filter((s) => s.status === 'scheduled' && parseDatum(s.datum) >= heute.getTime())
  .sort((a, b) => parseDatum(a.datum) - parseDatum(b.datum))
  .slice(0, 5);

const ergebnisse = mannschaftSpielplan.spiele
  .filter((s) => s.status === 'done' && s.ergebnis)
  .sort((a, b) => parseDatum(b.datum) - parseDatum(a.datum))
  .slice(0, 5);
---

<section class="mannschafts-block abschnitt" aria-labelledby={`mannschaft-${mannschaftTabellen.name}`}>
  <h2 id={`mannschaft-${mannschaftTabellen.name}`} class="mannschafts-block__titel">
    Mannschaft {mannschaftTabellen.name}
    <span class="mannschafts-block__liga">{mannschaftTabellen.ligaName}</span>
  </h2>

  {demo && (
    <Hinweis variant="demo">
      Beispieldaten – Saison 26/27 startet im September
    </Hinweis>
  )}

  <Tabelle
    caption={`Tabelle – ${mannschaftTabellen.ligaName}`}
    spalten={tabelleSpalten}
    zeilen={tabellenZeilenFuerUi(mannschaftTabellen.tabelle)}
    stand={stand}
  />

  <p class="mannschafts-block__link">
    <a href={mannschaftTabellen.myttTabelleUrl} rel="noopener noreferrer">
      Tabelle auf mytischtennis.de ansehen →
    </a>
  </p>

  {kommende.length > 0 && (
    <div class="mannschafts-block__spiele">
      <h3 class="mannschafts-block__untertitel">Nächste Spiele</h3>
      <ul class="spiel-liste spiel-liste--kompakt">
        {kommende.map((spiel) => (
          <li class="spiel-liste__eintrag">
            <time datetime={spiel.datum ?? undefined}>{formatSpielDatum(spiel.datum, spiel.uhrzeit)}</time>
            <span>{spiel.heim} – {spiel.gast}</span>
          </li>
        ))}
      </ul>
    </div>
  )}

  {ergebnisse.length > 0 && (
    <div class="mannschafts-block__spiele">
      <h3 class="mannschafts-block__untertitel">Letzte Ergebnisse</h3>
      <ul class="spiel-liste spiel-liste--kompakt">
        {ergebnisse.map((spiel) => (
          <li class="spiel-liste__eintrag">
            <time datetime={spiel.datum ?? undefined}>{formatSpielDatum(spiel.datum, spiel.uhrzeit)}</time>
            <span>{spiel.heim} {spiel.ergebnis} {spiel.gast}</span>
          </li>
        ))}
      </ul>
    </div>
  )}

  <p class="mannschafts-block__link">
    <a href={mannschaftSpielplan.myttSpielplanUrl} rel="noopener noreferrer">
      Spielplan auf mytischtennis.de ansehen →
    </a>
  </p>
</section>
