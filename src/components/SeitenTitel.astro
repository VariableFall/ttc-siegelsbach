---
interface Props {
  titel: string;
  lead?: string;
  hero?: boolean;
}

const { titel, lead, hero = false } = Astro.props;
---

<header class:list={['seiten-titel', { 'seiten-titel--hero': hero }]}>
  {hero && <span class="belag-balken" aria-hidden="true"></span>}
  <h1 class="seiten-titel__heading">{titel}</h1>
  {lead && <p class="seiten-titel__lead">{lead}</p>}
</header>
