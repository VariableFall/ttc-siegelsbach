---
import Base from '../layouts/Base.astro';
import SeitenTitel from '../components/SeitenTitel.astro';
import MannschaftsBlock from '../components/MannschaftsBlock.astro';
import { tabellen, spielplan } from '../data/index';
import { formatStand, mannschaftenGruppiert } from '../lib/spieldaten';
import { PAGE_DESCRIPTIONS } from '../lib/seo';

const currentPath = Astro.url.pathname;
const stand = formatStand(tabellen.stand);
const gruppen = mannschaftenGruppiert(tabellen, spielplan);
---

<Base title="Mannschaften" description={PAGE_DESCRIPTIONS.Mannschaften} currentPath={currentPath}>
  <SeitenTitel
    titel="Mannschaften"
    lead="Tabellen und Spielpläne unserer gemeldeten Mannschaften im BATTV."
  />

  {gruppen.map((g) => (
    <MannschaftsBlock
      name={g.name}
      wettbewerbe={g.wettbewerbe}
      demo={tabellen.demo}
      stand={stand}
    />
  ))}
</Base>
